 :actor/gates
 [{:gate/id "G1" :gate/name "cleanroom-interop" :gate/req "published API shapes + open standards ONLY (Orbit REST shape / Open-RMF / ROS 2 / DDS / MCAP / rosbag2 / LeRobot / Foxglove; nv-compat Isaac); NO vendor SDK, decompilation, trademarked code, or fork (sumitsubo G1 + nv-compat); vendor names in adapter docstrings only"}
  {:gate/id "G2" :gate/name "displacement-dividend-coupling" :gate/req "may not operate a fleet that displaces human labour LIVE unless the displaced cohort is registered for the tenure-weighted Displacement Dividend (ADR-2606032130); DEFINING gate inherited from the robotics wave"}
  {:gate/id "G3" :gate/name "transparent-force" :gate/req "every teleopCommand = an on-chain-anchored Datom; control+skill code open-source Apache-2.0; force class + activation governed by 1 SBT=1 vote via etzhayyim-force-authorization (Mission Charter §1.12.B); a teleopGrant without a force-authorization ref cannot be built"}
  {:gate/id "G4" :gate/name "no-server-key" :gate/req "the platform NEVER holds the key that commands a physical robot; teleopGrant serverHeldKey=false + encrypted-envelope ref only; every actuation command member-signed; server signature refused by construction (ADR-2605231525)"}
  {:gate/id "G5" :gate/name "murakumo-only" :gate/req "all policy training/eval + any perception assist via LiteLLM 127.0.0.1:4000 / edge Murakumo only (ADR-2605215000); no commercial GPU rental in the religious-corp path"}
  {:gate/id "G6" :gate/name "edge-envelope-policy" :gate/req "a shipped policyArtifact fits the baien edge envelope (WASM-32 + iPhone-12 + Android-4GB, frozen encoders; ADR-2605241900); larger policies = explicit baien-server-* carve-out"}
  {:gate/id "G7" :gate/name "outward-gated" :gate/req "ANY live actuation / live fleet enrollment / live demonstration capture is Council Lv6+ + operator gated (Lv7+ for :powered-actuation near humans); R0-R2 = design + simulation + replay only"}
  {:gate/id "G8" :gate/name "consent-bound-demonstration" :gate/req "demonstration episodes are the member's OWN labour data, encrypted (com.etzhayyim.encrypted.*), consent-scoped, cash=0 (a contribution, never paid work); part of the member's Wellbecoming trajectory (as-of, 非終末論)"}
  {:gate/id "G9" :gate/name "privacy-by-construction" :gate/req "teleop into homes/private spaces is on-device only — NO cloud video to third parties, NO surveillance feed, NO biometric capture; teleop link encrypted end-to-end + operator-scoped (kiyome G9); a remotely-operated robot is the opposite of a spy"}
  {:gate/id "G10" :gate/name "soft-rt-not-a-safety-system" :gate/req "deadman/e-stop/latency-fallback are best-effort soft-RT supervision; IEC 61508 / ISO 13849 safety-rated + hard-RT live actuation near humans = R5/Lv7+ (kotoba-os N2 precedent)"}
  {:gate/id "G11" :gate/name "kotoba-eavt-audit" :gate/req "fleet, mission, every command, every demonstration, every hand-off = Datoms (as-of, replayable); member + public can audit exactly what was commanded and what was learned"}
  {:gate/id "G12" :gate/name "sourcing-honesty" :gate/req ":representative fleet/registry; honest capability staging — real-world manipulation is unsolved, R-stages must not imply otherwise"}]

